# Build artifacts
dist/
build/
*.spec.bak

# Python virtual environments
.build_venv/
venv/
.venv/
__pycache__/
*.pyc
*.pyo

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Stray temp files from icon-converter tools (ICO Convert / RealFavicon
# Generator / etc.) — they auto-name like "mdmse-XXXXX-001.ico" and
# land alongside the real exports. The committed favicons live under
# webui/static/.
/mdmse-*.ico

# IDE (only ignore common config dirs, keep launch.json + the sync-smoke
# wrapper script for Claude)
.claude/*
!.claude/launch.json
!.claude/run-webui.sh
.vscode/
.idea/

# Secrets (never commit these!)
.env
*.env
secrets.yaml

# PyInstaller
*.manifest

# Generated by bundle_source.py (built fresh each time)
hermes_agent.zip
hermes_agent_bundle.zip
hermes_agent_bundle/

# Downloaded by build.bat / build.sh — bundled uv.exe / uv binary
tools/

# Static assets (unused placeholder)
/static/
