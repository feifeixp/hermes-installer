# OSS state sync — example .env for chat.neowow.studio (or any
# hermes-webui Docker deploy).
#
# Drop this at /opt/hermes-docker/.env (NOT in git!). docker compose
# auto-reads `.env` adjacent to docker-compose.yml and substitutes
# ${OSS_*} variables into the compose file.
#
# Why split secrets out of the compose YAML:
#   • The YAML is in git; AK/SK aren't
#   • Operator rotates AK/SK by editing .env + `docker compose up -d`
#     — no rebuild, no YAML diff
#   • If you fork hermes-installer the YAML stays generic
#
# All keys are REQUIRED when OSS_SYNC_ENABLED=1. Setting just SOME
# of them = container exits non-zero with a clear error (we'd rather
# fail loudly than silently produce "no backup" state).
# ──────────────────────────────────────────────────────────────────────

# Master switch. Set to "1" to enable sync, anything else (or unset)
# disables it cleanly — useful for development / one-off deploys.
OSS_SYNC_ENABLED=1

# Aliyun AccessKey (RAM user RECOMMENDED — scope policy to ONLY
# oss:PutObject + oss:GetObject + oss:ListObjects on your bucket).
# Console: https://ram.console.aliyun.com → Users → Create
OSS_ACCESS_KEY_ID=LTAI5tXXXXXXXXXXXXXXXXX
OSS_ACCESS_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Bucket region endpoint — same region as the bucket to avoid
# cross-region egress charges. Without https:// prefix.
#   • Hangzhou:  oss-cn-hangzhou.aliyuncs.com
#   • Shanghai:  oss-cn-shanghai.aliyuncs.com
#   • Singapore: oss-ap-southeast-1.aliyuncs.com
#   • Hong Kong: oss-cn-hongkong.aliyuncs.com
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com

# The bucket. Create in OSS console BEFORE the first container start.
# Suggested name: neowow-hermes-state (private ACL, versioning ON if
# you want point-in-time recovery, lifecycle rules for cost control).
OSS_BUCKET=neowow-hermes-state

# The user this container belongs to. Used as the prefix segment:
#   oss://${OSS_BUCKET}/users/${OSS_USER_ID}/hermes/
#
# For chat.neowow.studio Phase 1 (single Tencent box): set to the
# owner's 19-digit Neodomain userId.
# For Phase 2 per-user ECS: cloud-init templates this in.
OSS_USER_ID=1928091762437005312

# How often to push (seconds). 5 min default = at most 5 min of data
# loss on a hard crash. Lower = more bandwidth & OSS API calls,
# higher = more potential data loss. 60-600 is the sane range.
OSS_SYNC_INTERVAL_SECS=300
