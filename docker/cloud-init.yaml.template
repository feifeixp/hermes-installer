#cloud-config
# ─────────────────────────────────────────────────────────────────────────────
# Phase 2 per-user Hermes ECS cloud-init.
#
# The dashboard broker (app.neowow.studio/api/me/instance/start)
# substitutes the placeholders below before passing this as
# UserData to the cloud SDK's RunInstances call:
#
#   %USER_ID%               user's stable Neodomain userId (e.g. 31046663)
#   %DOMAIN%                full subdomain (e.g. chat-31046663.neowow.studio)
#   %ACME_EMAIL%            email for LetsEncrypt registration
#   %IMAGE%                 Docker image ref (resolved per registry availability)
#   %ACR_PULL_REGISTRY%     Docker registry hostname for login (e.g.
#                           zlxj-registry-vpc.cn-shanghai.cr.aliyuncs.com).
#                           Empty string = skip docker login (anonymous /
#                           public image — Hermes' image is private, so
#                           this should usually be set).
#   %ACR_PULL_USERNAME%     ACR sub-account with read-only pull permission
#   %ACR_PULL_PASSWORD%     companion password
#   %OSS_ACCESS_KEY_ID%     Aliyun OSS AK for state sync (M2)
#   %OSS_ACCESS_KEY_SECRET% companion secret (M2)
#   %OSS_ENDPOINT%          e.g. oss-cn-hangzhou.aliyuncs.com (M2)
#   %OSS_BUCKET%            usually neowow-hermes-state (M2)
#
# Boot timeline (first run):
#   00:00  Cloud-init starts (after kernel + cloud-init framework)
#   00:05  apt update (cached locally on Ubuntu image — ~10 s)
#   00:30  docker.io install (~50 s)
#   01:30  install ossutil + pull sessions from OSS (~30 s)
#   02:00  docker pull <IMAGE> (~1-3 min depending on image size + bandwidth)
#   03:30  docker compose up — Caddy starts requesting LE cert
#   04:00  LetsEncrypt challenge round-trip (HTTP-01 on :80)
#   04:30  hermes-webui health check passes — instance ready
#
# Total ~4-5 min from RunInstances to "serving traffic".
#
# Subsequent boots (after stop/start) skip the install steps because
# everything's already on disk; total ~30 s to ready. OSS pull still
# runs to catch up any state pushed from another instance (e.g. user
# spawned, stopped, then spawned again on a different ECS).
# ─────────────────────────────────────────────────────────────────────────────

package_update: true
package_upgrade: false

packages:
  - ca-certificates
  - curl
  - gnupg

write_files:
  # /opt/hermes-docker/docker-compose.yml — same shape as Phase 1's
  # chat.neowow.studio. Per-user changes: HERMES_INSTANCE_OWNER_USERID
  # env var (so WebUI rejects requests from other users' JWTs) +
  # this instance's subdomain in the Caddyfile.
  - path: /opt/hermes-docker/docker-compose.yml
    permissions: '0644'
    content: |
      services:
        caddy:
          image: caddy:2.8-alpine
          container_name: hermes-caddy
          restart: unless-stopped
          ports:
            - "80:80"
            - "443:443"
            - "443:443/udp"
          volumes:
            - ./Caddyfile:/etc/caddy/Caddyfile:ro
            - caddy_data:/data
            - caddy_config:/config
          networks: [hermes]
          depends_on:
            hermes-webui:
              condition: service_healthy

        hermes-webui:
          image: %IMAGE%
          container_name: hermes-webui
          restart: unless-stopped
          environment:
            HERMES_WEBUI_AUTH_MODE: neodomain
            HERMES_WEBUI_HOST: 0.0.0.0
            HERMES_WEBUI_PORT: 7891
            HERMES_WEBUI_FOREGROUND: "1"
            HERMES_WEBUI_STATE_DIR: /opt/hermes/.hermes/webui
            # Per-instance owner. WebUI's auth.py enforces that the
            # JWT's userId matches this value — otherwise other users
            # with valid neoTokens could access THIS user's instance.
            HERMES_INSTANCE_OWNER_USERID: "%USER_ID%"
            # Phase β: lock the onboarding wizard to the Neowow Coding
            # Plan card only. Hides openai / anthropic / openrouter /
            # ollama / custom from the dropdown so spawned cloud
            # instances always bill through our /api/me/chat proxy
            # (= credits + plan enforcement = revenue). Desktop builds
            # may flip this off if the user explicitly wants to BYO
            # provider, but cloud is hard-locked.
            HERMES_NEOWOW_ONLY: "1"
          # M2: bind-mount (NOT named volume) so oss-sync.sh on the host
          # can read/write the same bytes the WebUI sees. Named volumes
          # live inside the Docker overlay storage and can't be ergonomically
          # rsync'd. /var/lib/hermes-state is created by cloud-init's
          # runcmd before this container starts.
          volumes:
            - /var/lib/hermes-state:/opt/hermes/.hermes
          expose: ["7891"]
          networks: [hermes]
          healthcheck:
            test: ["CMD", "curl", "-fsS", "http://127.0.0.1:7891/health"]
            interval: 10s
            timeout: 3s
            start_period: 30s
            retries: 5

      volumes:
        caddy_data:   {}
        caddy_config: {}

      networks:
        hermes:
          driver: bridge

  - path: /opt/hermes-docker/Caddyfile
    permissions: '0644'
    content: |
      {
          email %ACME_EMAIL%
      }

      %DOMAIN% {
          reverse_proxy hermes-webui:7891 {
              header_up X-Forwarded-Proto {scheme}
              header_up X-Forwarded-Host  {host}
              flush_interval -1
          }
          request_body {
              max_size 50MB
          }
          log {
              output stdout
              format console
          }
      }

  # Hourly auto-update cron — same as Phase 1 chat.neowow.studio.
  - path: /etc/cron.d/hermes-auto-update
    permissions: '0644'
    content: |
      SHELL=/bin/bash
      PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

      0 * * * * root cd /opt/hermes-docker && echo "=== $(date -Iseconds) ===" >> /var/log/hermes-update.log && /usr/bin/docker compose pull >> /var/log/hermes-update.log 2>&1 && /usr/bin/docker compose up -d >> /var/log/hermes-update.log 2>&1

  # ── M2: OSS state sync configuration ─────────────────────────────────
  # Read by /opt/hermes-docker/oss-sync.sh. Cred values substituted by
  # the broker so they never live in any source tree. Permissions 0600
  # so even other users on the same VM (if any) can't read.
  - path: /etc/default/hermes-oss-sync
    permissions: '0600'
    owner: root:root
    content: |
      OSS_ACCESS_KEY_ID="%OSS_ACCESS_KEY_ID%"
      OSS_ACCESS_KEY_SECRET="%OSS_ACCESS_KEY_SECRET%"
      OSS_ENDPOINT="%OSS_ENDPOINT%"
      OSS_BUCKET="%OSS_BUCKET%"
      OSS_PREFIX="users/%USER_ID%/hermes"
      LOCAL_PATH="/var/lib/hermes-state"
      OSSUTIL="/usr/local/bin/ossutil"

  # ── M2: 5-minute push cron ──────────────────────────────────────────
  # Every 5 min, push any new chat-session writes to OSS. Failures are
  # tolerated (next cron tick retries); we don't want the sync to take
  # the instance down.
  - path: /etc/cron.d/hermes-oss-sync
    permissions: '0644'
    content: |
      SHELL=/bin/bash
      PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

      */5 * * * * root /opt/hermes-docker/oss-sync.sh push > /dev/null 2>&1 || true

  # ── M2: shutdown hook — push state one last time before halt ─────────
  # ExecStop runs synchronously during shutdown. We give it 60s; the
  # rsync of a typical sessions DB (few hundred KB) takes < 2s, so this
  # is just paranoia.
  - path: /etc/systemd/system/hermes-oss-shutdown.service
    permissions: '0644'
    content: |
      [Unit]
      Description=Push Hermes state to OSS before shutdown
      DefaultDependencies=no
      Before=shutdown.target poweroff.target halt.target reboot.target
      RequiresMountsFor=/var/lib/hermes-state

      [Service]
      Type=oneshot
      RemainAfterExit=true
      # No-op start — the work happens in ExecStop, which runs when the
      # unit is stopped (i.e. on system shutdown).
      ExecStart=/bin/true
      ExecStop=/opt/hermes-docker/oss-sync.sh push
      TimeoutStopSec=60s

      [Install]
      WantedBy=shutdown.target

runcmd:
  # ── Install Docker via the official one-liner. Faster than the apt
  # ── debian-keyring dance + works on any reasonable Linux. ~60s.
  - [bash, -c, "curl -fsSL https://get.docker.com | sh"]
  - systemctl enable --now docker

  # ── M2: download ossutil + the oss-sync.sh script.
  # ── ossutil is a single Go binary; ~20 MB; we host on Aliyun CDN.
  - [bash, -c, "curl -fsSL --retry 3 https://gosspublic.alicdn.com/ossutil/v2/2.0.5/ossutil-2.0.5-linux-amd64.zip -o /tmp/ossutil.zip && cd /tmp && unzip -o ossutil.zip && mv -f ossutil-*/ossutil /usr/local/bin/ossutil && chmod +x /usr/local/bin/ossutil"]
  - [bash, -c, "curl -fsSL --retry 3 https://raw.githubusercontent.com/feifeixp/hermes-installer/main/docker/oss-sync.sh -o /opt/hermes-docker/oss-sync.sh && chmod +x /opt/hermes-docker/oss-sync.sh"]

  # ── M2: probe OSS access (fail-fast if creds wrong) + pull existing state.
  # ── If verify fails we still proceed — better to run with no remote
  # ── backup than to fail the entire spawn. Logs go to journal.
  - [bash, -c, "/opt/hermes-docker/oss-sync.sh verify || echo 'WARNING: OSS not accessible; sessions WILL NOT persist across destroy'"]

  # ── The hermes_state docker volume mounts at a host path; we point
  # ── oss-sync at that path so sync targets the live data, not container
  # ── ephemeral storage. Volume bind: /var/lib/hermes-state → container
  # ── /opt/hermes/.hermes
  - [bash, -c, "mkdir -p /var/lib/hermes-state"]
  - [bash, -c, "/opt/hermes-docker/oss-sync.sh pull"]

  # ── Docker login to private registry (Aliyun ACR Enterprise edition).
  # ── Conditional: only run when ACR_PULL_* placeholders are filled in.
  # ── Empty string means "image is anonymous / public", skip the login.
  # ── Uses --password-stdin so the password never appears in process
  # ── list / cloud-init log file (cloud-init logs full runcmd output
  # ── otherwise — that's the kind of leak we want to avoid).
  #
  # NOTE: we use `printf '%s'` NOT `printf '%%s'` here. Earlier version
  # used the latter thinking sed would unescape the double-% — sed doesn't,
  # and printf interprets %% as an escape for literal `%`, so the actual
  # value piped to docker login was the two-char string "%s" instead of
  # the password. Caused 401 unauthorized + spent 3 spawn cycles debugging.
  # Passwords containing literal single quotes still break this — none of
  # ours do today, so deferred. Switch to write_files-based approach
  # if a user's password ever contains '.
  - [bash, -c, "if [ -n '%ACR_PULL_REGISTRY%' ] && [ -n '%ACR_PULL_USERNAME%' ]; then printf '%s' '%ACR_PULL_PASSWORD%' | docker login '%ACR_PULL_REGISTRY%' -u '%ACR_PULL_USERNAME%' --password-stdin; fi"]

  # ── Pull the Hermes image upfront (faster + clearer error than
  # ── waiting for compose to do it implicitly). ~1-3 min.
  - [bash, -c, "docker pull %IMAGE%"]

  # ── Pull Caddy too while we're at it (so first compose up is fast).
  - [bash, -c, "docker pull caddy:2.8-alpine"]

  # ── Bring the stack up. compose internally waits for hermes-webui
  # ── to be healthy before starting Caddy (depends_on condition).
  - [bash, -c, "cd /opt/hermes-docker && docker compose up -d"]

  # ── Reload cron so /etc/cron.d/hermes-{auto-update,oss-sync} take
  # ── effect now (otherwise they'd need a system restart).
  - systemctl reload cron

  # ── Enable the shutdown hook so OSS gets a final push on poweroff.
  - systemctl daemon-reload
  - systemctl enable hermes-oss-shutdown.service
  - systemctl start hermes-oss-shutdown.service

  # ── Ping the broker so it knows this instance is ready. The broker
  # ── will flip state from 'cloud_init' to 'running'. We deliberately
  # ── don't fail cloud-init if this curl fails — the broker will
  # ── eventually detect via its own status polling.
  #
  # ── The URL + auth token are templated in by the broker (omitted
  # ── here for M1 simplicity — broker polls instead). Future M2 can
  # ── add a callback for instant-ready signaling.

# Skip useless legacy cloud-init modules to shave a few seconds off.
final_message: "Hermes Phase 2 instance ready (%DOMAIN%)"
