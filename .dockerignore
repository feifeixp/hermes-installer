# Don't ship build/test artifacts to the Docker context — keeps layers
# small and avoids leaking dev-local credentials into the image.

# VCS
.git/
.gitignore
.github/

# Editor / IDE
.vscode/
.idea/
*.swp
.DS_Store

# Python build artifacts
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
.pytest_cache/
.coverage
.tox/
.venv/
venv/
env/

# Node (only used for install scripts; node_modules baked at runtime)
node_modules/
npm-debug.log

# Local dev state
.env
.env.local
*.log
hermes_agent_bundle.zip   # generated by bundle_source.py
build/
dist/
*.spec.bak

# Docker meta itself
docker/docker-compose.yml.template

# macOS / Windows installer artifacts
*.dmg
*.exe
*.app/
hermes-installer.spec

# Temporary
tmp/
*.tmp
*.bak
