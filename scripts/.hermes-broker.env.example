# ─────────────────────────────────────────────────────────────────────────────
# Hermes broker — manual-spawn config template.
#
# Copy this file to one of:
#   ~/.hermes-broker.env                 (recommended — applies to all repos)
#   ./scripts/.hermes-broker.env         (repo-local — git-ignored)
#
# Then fill in the values. The spawn-hermes.sh / stop / delete scripts
# read whichever they find first. Direct env vars on the command line
# still take precedence over both.
#
# Get these from your Aliyun ops colleague — see the on-boarding checklist
# in docs/ (or paste from the email/chat they sent you).
# ─────────────────────────────────────────────────────────────────────────────

# ── 1. Aliyun RAM 子账号 — broker AccessKey ──────────────────────────────────
# Required.  Profile name in aliyun-cli config; defaults to "hermes-broker"
# if unset. Run `aliyun configure --profile $ALIYUN_PROFILE --mode AK`
# once to wire AK ID/Secret into aliyun-cli, then come back here.
ALIYUN_PROFILE=hermes-broker

# ── 2. Region + VPC ──────────────────────────────────────────────────────────
ALIYUN_REGION=cn-hongkong
# Find via: aliyun vpc DescribeVSwitches --RegionId $ALIYUN_REGION
ALIYUN_VSWITCH_ID=vsw-bp1xxxxxxxxxxxxxxxxx

# ── 3. Security Group (must have TCP 22/80/443 inbound) ──────────────────────
# Find via: aliyun ecs DescribeSecurityGroups --RegionId $ALIYUN_REGION
ALIYUN_SECURITY_GROUP_ID=sg-bp1xxxxxxxxxxxxxxx

# ── 4. ACR pull credentials — for the spawned ECS to docker login ────────────
# Use a READ-ONLY sub-account on the ACR side (not the master account).
# Use the -vpc. endpoint when ECS region == ACR region (faster + free
# internal traffic). For cross-region, drop the -vpc. suffix.
ACR_PULL_REGISTRY=zlxj-registry-vpc.cn-shanghai.cr.aliyuncs.com
ACR_PULL_USERNAME=hermes-instance-puller
ACR_PULL_PASSWORD=__PUT_PULL_TOKEN_HERE__

# ── 5. The Docker image to deploy ────────────────────────────────────────────
# Format: <registry>/<namespace>/<repo>:<tag>
# Default is the enterprise ACR latest; override per-spawn via cli arg.
HERMES_WEBUI_IMAGE=zlxj-registry-vpc.cn-shanghai.cr.aliyuncs.com/zlxj/hermes-webui:latest

# ── 6. ACME / LE registration email (one per platform, not per user) ─────────
# LetsEncrypt sends cert-expiry warnings here. Doesn't need to match any
# user account; it's purely platform ops.
ACME_EMAIL=admin@neowow.studio

# ── 7. Cloudflare DNS — for writing chat-<userId>.neowow.studio A records ───
# Token needs `Zone.DNS.Edit` scope on the neowow.studio zone only.
# Create at: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=__PUT_CF_TOKEN_HERE__
# Zone ID: visible on the neowow.studio dashboard right sidebar
CLOUDFLARE_ZONE_ID=__PUT_CF_ZONE_ID_HERE__

# ── 8. OSS state sync — optional, but recommended for prod ───────────────────
# When set, the spawned ECS rsyncs its hermes_state/ to OSS every 5 min so
# users don't lose chat history when the instance is destroyed/recreated.
# Empty values disable sync (cloud-init still spawns OK).
OSS_ACCESS_KEY_ID=__OPTIONAL__
OSS_ACCESS_KEY_SECRET=__OPTIONAL__
OSS_ENDPOINT=oss-cn-hangzhou-internal.aliyuncs.com
OSS_STATE_BUCKET=neowow-hermes-state

# ── 9. Defaults (rarely need to override) ────────────────────────────────────
# Instance type — 2C 4G hourly billing
ALIYUN_INSTANCE_TYPE=ecs.t6-c1m2.large
# Ubuntu 22.04 family (Aliyun resolves to latest version on RunInstances)
ALIYUN_IMAGE_ID=ubuntu_22_04_x64_20G_alibase_
# Outbound bandwidth cap (Mbps). 5 is enough for HTTPS / LE / chat;
# users uploading large attachments may want 10-20.
ALIYUN_BANDWIDTH_MBPS=5
# System disk size (GiB). 40 fits image + state for typical users.
ALIYUN_DISK_GB=40
